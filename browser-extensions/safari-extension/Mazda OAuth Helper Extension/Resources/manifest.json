{
  "manifest_version": 3,
  "name": "Mazda OAuth Helper",
  "version": "1.1.0",
  "description": "Captures Mazda mobile OAuth redirects for use with pymazda library",
  "permissions": ["webNavigation", "tabs", "cookies"],
  "host_permissions": ["*://*.mazda.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mazda OAuth Helper"
  }
}
